#!/bin/sh
rm() { echo $@; /bin/rm -vI $@; }
fu() { git commit -a -m "$1" && git push origin; }
alias mv='mv -iv'
alias fin='. fin'
alias fs='. fs'
alias v='jproc_vimcd'
alias l='jproc_lfcd'
# alias gw='rgrep'
alias rs='res4thum'
# alias z='zathura'
alias g='git'
# alias zr='zaread'
alias pv='pavucontrol'
# alias i='sxiv'
alias pm='pulsemixer'
alias ht='htop'
# alias sht='sudo htop'
alias ki='killall'
# alias pq='yay -Q | fzf'
alias sen='watch -n1 "tempnfan ; echo '' ; nvidia-smi"'
alias dt='cd /tmp'
alias sr='cd $HOME/.local/bin/scripts'
alias cl='cd $HOME/.local/src'
alias sp='sync && sync && systemctl suspend'
alias prs="cat $HOME/.cache/yay/__list_of_packages__ | fzf --multi --ansi --preview 'yay -Qi {1}'"
alias par='yay --needed -S'
alias u='system-update-aur'
alias ua='system-update'
alias prq='yay -Q | fzf'
alias pacman='sudo pacman'
alias systl='sudo systemctl'
alias sv='sudo v'
alias c='/usr/bin/git --git-dir=$HOME/.dotfiles --work-tree=$HOME'
alias cu='c add $(realpath $HOME/.local/bin/scripts $HOME/.nvim $HOME/.zsh $HOME/.config/alacritty $HOME/.config/lf) && c commit -a -m new && c push --force'
alias cpl='c pull'
alias gl='cd $HOME/.local/src/glibc'
alias gls='cd $HOME/.local/src/glibc-strstr-avx2'
alias glm='cd $HOME/.local/src/glibc-memmem-avx2'
alias bs='cd $HOME/.local/src/freebsd-src/lib/libc'
alias mu='cd $HOME/.local/src/musl/src'
alias vd='v $HOME/.local/src/dwm/config.h'
alias vdw='v $HOME/.local/src/dwmblocks-fast/dwmblocks-fast.c'
alias vsl='v $HOME/.local/src/slstatus/config.h'
alias vlf='v $HOME/.lfrc'
alias vs='v $HOME/.local/src/st/config.h'
alias vmpv='v $HOME/.config/mpv/mpv.conf'
alias xi='v $HOME/.xinitrc'
alias zs='v $HOME/.zsh/.zshrc'
alias va='v $HOME/.zsh/.zsh_aliases'
alias vp='v $HOME/.config/picom.conf'
alias vvim='v $HOME/.nvim/defaults.vim'
alias zf='v $HOME/.zsh/jproc'
alias vsi='v $HOME/.local/share/alias/sites'
alias vb='v $HOME/.zsh/.bashrc'
alias tor='jproc_lfcd $HOME/Downloads/torrent'
alias rec='jproc_lfcd ~/Videos/Recordings'
alias vid='jproc_lfcd ~/Videos'
alias cs='cd $HOME/.zsh'
alias slt='killall slstatus && nohup slstatus > /dev/null 2>&1 &'
alias dwt='killall dwmblocks && nohup dwmblocks > /dev/null 2>&1 &'
alias sf='v /etc/fan2go/fan2go.yaml'
alias dfh="df -h | head -n1; df -h | /bin/grep -e /$ -e /home -e /tmp"
alias update-grub='sudo grub-mkconfig -o /boot/grub/grub.cfg'
alias upvim="$EDITOR -c ':PlugUpdate' -c ':CocUpdate'"
alias yt='yt-dlp --embed-metadata -i'
alias yta='yt -x -f bestaudio/bestub'
alias ls='ls -hN --color=auto --group-directories-first'
alias grep='grep --color=auto'
alias diff='diff --color=auto'
# alias hi='highlight --out-format=ansi'
alias ip='ip --color=auto'
alias kdb='killall dwmblocks'
# alias info='info --vi-keys'
alias pac='sudo pacman -Syu'
alias skr="cd $HOME/Pictures/Screenshots/mpv-screenshots"
alias bu='jproc_lfcd $HOME/books'
alias mi="cd $HOME/books/Mythology"
alias mk='make -j6'
alias his="history | fzf | xclip -sel c"
alias hisa="cat $HOME/.cache/zsh/history | fzf | xclip -sel c"
