{
    "clangd.disableSnippetCompletion": false,
	"clangd.disableDiagnostics": false,
	"clangd.path": "/usr/bin/clangd",
	"clangd.fallbackFlags": [
		"-xc",
		"--analyze",
		"-Wall",
		"-Wextra",
		"-Wpedantic",
		"-pedantic",
		"-pedantic-errors",
		"-Wuninitialized",
		"-Wshadow",
		"-Warray-bounds",
		"-Wnull-dereference",
		"-Wunused",
		"-Wwrite-strings",
		"-Wsign-conversion",
		"-Xanalyzer",
		"-Wundef",
		"-Wshadow",
		"-Wconversion",
		"-Wsign-conversion",
		"-Wdouble-promotion",
		"-Wcast-align",
		"-Wimplicit-fallthrough",
		"-Wswitch-enum",
		"-Wformat=2",
		"-Wnull-dereference",
		"-Wuninitialized",
		"-Wconditional-uninitialized",
		"-Wredundant-decls",
		"-Wnested-anon-types",
		"-Wgnu",
		"-Wstrict-aliasing=2",
		"-Wstrict-overflow=5",
		"-Warray-bounds",
		"-Wvla",
		"-Walloca",
		"-Walloc-zero",
		"-Wno-unused-parameter",
		"-Wno-implicit-int-conversion",
		"-Wno-strict-prototypes"
	],
	"clangd.arguments": [
		"--background-index",
		"--background-index-priority=low",
		"--clang-tidy",
		"--clang-tidy-checks=clang-diagnostic-*,clang-analyzer-*,bugprone-*,performance-*,cert-*,cppcoreguidelines-*"
	],

    "perl.enable": false,
    "perlnavigator.enable": true,
    "perlnavigator.perlcriticEnabled": true,
    "perlnavigator.perltidyEnabled": true,
    "perlnavigator.enableWarnings": true,

    "sh.enable": true,
	"sh.commandPath": "bash-language-server",
    "bashIde.enableSourceErrorDiagnostics": true,
    "bashIde.shfmt.languageDialect": "posix",

	"languageserver": {
		           "csharp-ls": {
			"enable": false,
			"command": "csharp-ls",
			"filetypes": [
				"cs"
			],
			"rootPatterns": [
				"*.csproj",
				".vim/",
				".git/",
				".hg/"
			]
		},
		           "awk": {
			"command": "awk-language-server",
			"filetypes": [
				"awk"
			]
		}
	},

	"eslint.onIgnoredFiles": "off"
}
