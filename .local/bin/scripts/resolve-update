#!/bin/sh
# Check for updates weekly
update_interval=7
# Updater script
UPDATER="$HOME/.local/src/Davinci-Resolve-Updater/update-resolve.sh"
# When to update
next_update_file=$HOME/.cache/resolve-update

[ -f "$next_update_file" ] || echo $update_interval > "$next_update_file"

LOCK=/tmp/resolve-update.lock
[ -f $LOCK ] && exit
touch "$LOCK"

next_update=$(cat "$next_update_file")
# Need to update
if [ "$next_update" -le 0 ]; then
	interval=$update_interval
	"$UPDATER"	
# No need to update
else
	interval=$((interval - 1))
fi
# Update interval
echo "$interval" >"$next_update_file"
