#!/bin/sh
image=$1
scale=$2
out=${image%.*}-hd-${scale}x.png
USAGE="usage: $(basename "$0") <image> <scale>"

if [ -z "$UPSCALER" ]; then
	UPSCALER=realesrgan-x4plus-anime
fi

upscale()
{
	realesrgan-ncnn-vulkan -i "$1" -o "$out" -s 4 -n "$UPSCALER" -v
}

resize()
{
	resolution=$(identify -ping "$out" | awk '{print $3}' | sed 's/x.*//')
	if [ ! -z "$RESIZE" ]; then
		if [ ! -z "$RESIZE_RES" ]; then
			RESIZE_RES=2400
		fi
		if [ "$resolution" -gt "$RESIZE_RES" ]; then
			res "$out" "$RESIZE_RES" 
			rm "$out"
		fi
	fi
}

case $image in
*.png | *.jpg | *.jpeg | *.webp) ;;
*)
	echo "$USAGE"
	echo 'Not an image file!'
	exit 1
	;;
esac

if [ "$scale" -le 4 ]; then
	n=0
	scale=4
elif [ "$scale" -le 16 ]; then
	n=1
	scale=$((scale * scale))
elif [ "$scale" -le 32 ]; then
	n=2
	scale=$((scale * scale * scale))
elif [ "$scale" -le 64 ]; then
	n=3
	scale=$((scale * scale * scale * scale))
else
	echo "$USAGE"
	echo 'Illegal number used! Use 1, 2, 3, 4, 16, 32, or 64 instead.'
	exit 1
fi

upscale "$image"

while [ "$n" -gt 0 ]; do
	upscale "$out"
	n=$((n - 1))
done

resize
