#!/bin/sh
image=$1
scale=$2

USAGE="usage: $(basename "$0") <image> <scale>"
if [ -z "$UPSCALER" ]; then
	UPSCALER=realesrgan-x4plus-anime
fi

case $image in
*.png | *.jpg | *.jpeg | *.webp) ;;
*)
	echo "$USAGE"
	echo 'Not an image file!'
	exit 1
	;;
esac

if [ "$scale" -le 4 ]; then
	n=0
	scale=4
elif [ "$scale" -le 16 ]; then
	n=1
	scale=$((scale * scale))
elif [ "$scale" -le 32 ]; then
	n=2
	scale=$((scale * scale * scale))
elif [ "$scale" -le 64 ]; then
	n=3
	scale=$((scale * scale * scale * scale))
else
	echo "$USAGE"
	echo 'Illegal number used! Use 1, 2, 3, 4, 16, 32, or 64 instead.'
	exit 1
fi

out=${1%.*}-hd-${scale}x.png

upscale()
{
	realesrgan-ncnn-vulkan -i "$image" -o "$out" -s 4 -n "$UPSCALER" -v
}

upscale "$image"

i=0
while [ $i -lt $n ]; do
	upscale "$out"
	i=$((i = i + 1))
done

if [ ! -z "$RESIZE" ]; then
	if [ ! -z "$RESIZE_RES" ]; then
		RESIZE_RES=2400
	fi
	resolution=$(identify -ping "$out" | awk '{print $3}' | sed 's/x.*//')
	if [ "$resolution" -gt "$RESIZE_RES" ]; then
		res "$out" "$RESIZE_RES" 
		rm "$out"
	fi
fi
